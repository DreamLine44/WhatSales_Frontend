# WhatSales Frontend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it contains secrets.

VITE_API_URL=https://web-production-32cc.up.railway.app

# ─── Super Admin Credentials ──────────────────────────────────────────────────
# Must match SUPER_ADMIN_API_KEY in your Railway backend Variables.
VITE_ADMIN_TENANT_ID=whatsales-admin
VITE_ADMIN_API_KEY=your-64-char-super-admin-api-key-here

# ─── IMPORTANT: Railway CORS_ORIGIN ───────────────────────────────────────────
# In Railway → your backend service → Variables, set CORS_ORIGIN to your
# deployed frontend URL(s), comma-separated:
#
#   CORS_ORIGIN=https://your-app.vercel.app,http://localhost:3000
#
# Without this, the backend BLOCKS all requests from your frontend in production!
