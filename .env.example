# ─── WhatSales Frontend — Environment Variables ────────────────────────────────
#
# SECURITY NOTE: VITE_* values are bundled into the client-side JS bundle and are
# visible in browser DevTools. Keep the admin key strong and unique, and ensure your
# backend enforces proper server-side authentication on all /admin/* routes.

# Your Railway backend URL (no trailing slash)
VITE_API_URL=https://your-backend.up.railway.app

# Super-admin API key — must match SUPER_ADMIN_API_KEY in your Railway backend Variables.
VITE_ADMIN_API_KEY=your-super-admin-key-here

# ─── IMPORTANT: Railway CORS_ORIGIN ───────────────────────────────────────────
# In Railway → your backend service → Variables, set CORS_ORIGIN to your
# deployed frontend URL(s), comma-separated:
#
#   CORS_ORIGIN=https://your-app.vercel.app,http://localhost:3000
#
# Without this, the backend BLOCKS all requests from your frontend in production!
