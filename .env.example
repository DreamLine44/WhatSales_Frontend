# ─────────────────────────────────────────────────────────────────────────────
# WhatSales Frontend — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — NEVER commit real credentials.
#
# All variables must be prefixed with VITE_ to be exposed to the browser bundle.
# Vite only injects these at BUILD TIME — after changing them, redeploy.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the WhatSales backend API (no trailing slash).
# Local development:  http://localhost:5000
# Production:         your Railway deployment URL
VITE_API_URL=https://your-backend.up.railway.app

# MongoDB _id of the super-admin Tenant document.
# The login page compares the entered Tenant ID against this value to decide
# whether to route to adminLogin() or the regular tenant login flow.
#
# How to find it:
#   1. After your first Railway deploy, check the startup logs — seed.js prints it.
#   2. Or query MongoDB Atlas: db.tenants.findOne({ name: /admin/i }, { _id: 1 })
VITE_ADMIN_TENANT_ID=your_super_admin_tenant_id_here
